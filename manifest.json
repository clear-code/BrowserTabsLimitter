{
  "manifest_version": 3,
  "name": "Tab Limiter",
  "version": "1.0",

  "icons": {
    "16": "icons/icons_16.png",
    "48": "icons/icons_48.png",
    "128": "icons/icons_128.png"
  },

  "permissions": [
    "tabs",
    "storage",
    "notifications"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  }
}